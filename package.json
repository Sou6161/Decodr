{
  "name": "arcloom",
  "version": "0.1.0",
  "private": true,
  "description": "Arcloom — Understand any React codebase in minutes. Intelligent React + TypeScript codebase analysis platform.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace @arcloom/api",
    "dev:web": "npm run dev --workspace @arcloom/web",
    "build": "npm run build --workspace @arcloom/types && npm run build --workspace @arcloom/api && npm run build --workspace @arcloom/web",
    "build:types": "npm run build --workspace @arcloom/types",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @arcloom/api",
    "db:migrate": "npm run db:migrate --workspace @arcloom/api",
    "db:studio": "npm run db:studio --workspace @arcloom/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.2"
  }
}
