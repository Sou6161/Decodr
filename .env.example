# ──────────────────────────────────────────────────────────────
# Arcloom environment — copy to .env and fill in.
# Loaded by apps/api. The web app reads only VITE_* vars.
# ──────────────────────────────────────────────────────────────

# Backend
NODE_ENV=development
API_PORT=4000
# Comma-separated origins allowed by CORS
WEB_ORIGIN=http://localhost:5173

# Database (local Homebrew PostgreSQL 17). Include your DB role explicitly —
# e.g. your macOS username — so Prisma's driver authenticates correctly.
DATABASE_URL=postgresql://USER@localhost:5432/arcloom?schema=public

# File storage (where uploaded ZIPs are extracted)
STORAGE_DIR=./storage
MAX_UPLOAD_MB=50

# AI provider abstraction. Provider is one of: openai | claude | gemini | ollama
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# Optional: point at an OpenAI-compatible gateway (e.g. https://api.api-hub.ai/v1).
# Leave blank to use OpenAI directly. When set, prefix models as the gateway
# expects (e.g. AI_MODEL=openai/gpt-5-nano).
OPENAI_BASE_URL=

# Frontend (Vite) — must be prefixed with VITE_
VITE_API_BASE_URL=http://localhost:4000
