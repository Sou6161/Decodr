# ──────────────────────────────────────────────────────────────
# Arcloom environment — copy to .env and fill in.
# Loaded by apps/api. The web app reads only VITE_* vars.
# ──────────────────────────────────────────────────────────────

# Backend
NODE_ENV=development
API_PORT=4000
# Comma-separated origins allowed by CORS
WEB_ORIGIN=http://localhost:5173

# Database (local Homebrew PostgreSQL 17). Include your DB role explicitly —
# e.g. your macOS username — so Prisma's driver authenticates correctly.
DATABASE_URL=postgresql://USER@localhost:5432/arcloom?schema=public

# File storage (where uploaded ZIPs are extracted)
STORAGE_DIR=./storage
MAX_UPLOAD_MB=500

# AI provider abstraction. Provider is one of: openai | claude | gemini | ollama
AI_PROVIDER=openai
# A namespaced OpenRouter model (openai/gpt-4o-mini, anthropic/claude-3.5-sonnet)
# or "openrouter/free" to auto-route to free models (slower, variable quality).
AI_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
# Optional: point at an OpenAI-compatible gateway. Leave blank to use OpenAI
# directly. For OpenRouter use https://openrouter.ai/api/v1.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_SITE_NAME=Arcloom
# Enable OpenRouter reasoning (reasoning: { enabled: true }). Slower; pairs well
# with openrouter/free which routes to reasoning-capable models.
AI_REASONING=false

# Frontend (Vite) — must be prefixed with VITE_
VITE_API_BASE_URL=http://localhost:4000
# Client-side upload size guard (should match MAX_UPLOAD_MB)
VITE_MAX_UPLOAD_MB=500
